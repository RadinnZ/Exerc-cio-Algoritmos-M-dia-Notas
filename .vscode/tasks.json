{
  "version": "2.0.0",
  "tasks": [{
    "type": "cppbuild",
    "label": "Compilar C++",
    "command": "/usr/bin/g++",
    "args": [
      "-g", "-std=c++17",
      "${file}",
      "-o", "${fileDirname}/${fileBasenameNoExtension}"
    ],
    "group": { "kind": "build", "isDefault": true },
    "problemMatcher": "$gcc"
  }]
}